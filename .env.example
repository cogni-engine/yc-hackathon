NEXT_PUBLIC_HOCUSPOCUS_URL=

# Supabase (client + hocuspocus). RLS is disabled, so the publishable key has
# full access — hackathon only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Hocuspocus (server-side) reads the same project.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-side only. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# gbrain sidecar (company brain) — embedding provider.
# By default it reuses GEMINI_API_KEY above (Gemini `gemini-embedding-001`), so
# nothing extra is needed. To use a different provider, set one of these instead
# (they take priority via GBRAIN_EMBEDDING_MODEL, else Gemini is used):
# OPENAI_API_KEY=
# VOYAGE_API_KEY=
# ZEROENTROPY_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=   # explicit Gemini key (else GEMINI_API_KEY is reused)
# GBRAIN_EMBEDDING_MODEL=google:gemini-embedding-001   # force a specific model

# Where the app + hocuspocus reach the gbrain bridge. In docker compose this is
# set to http://gbrain:3131 automatically; for local `pnpm dev` use localhost.
# GBRAIN_BRIDGE_URL=http://localhost:3131
# GBRAIN_BRIDGE_TOKEN=   # optional shared secret; set the same value on the bridge
