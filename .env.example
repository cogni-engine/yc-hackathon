NEXT_PUBLIC_HOCUSPOCUS_URL=

# Supabase (client + hocuspocus). RLS is disabled, so the publishable key has
# full access — hackathon only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Hocuspocus (server-side) reads the same project.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-side only. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Recall.ai — real-time meeting transcription into notes (Next.js side).
# API key + region from your Recall dashboard (host is https://{region}.recall.ai).
RECALL_API_KEY=
RECALL_REGION=us-west-2
# Where Recall sends transcripts. Defaults to this app's own
# /api/recall/webhook. Recall (cloud) can't reach localhost, so for local dev
# set this to a public tunnel of `next dev`, e.g.
#   ngrok http 3000   →   https://<id>.ngrok-free.app/api/recall/webhook
# In production (Vercel) leave blank to auto-use the deployment URL.
# RECALL_WEBHOOK_URL=
# Optional transcript language (default: ja).
# RECALL_LANGUAGE=ja
# WebSocket URL the webhook uses to write into hocuspocus. Defaults to
# NEXT_PUBLIC_HOCUSPOCUS_URL (or ws://localhost:1234).
# HOCUSPOCUS_URL=
