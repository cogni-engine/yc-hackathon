NEXT_PUBLIC_HOCUSPOCUS_URL=

# Supabase (client + hocuspocus). RLS is disabled, so the publishable key has
# full access — hackathon only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Hocuspocus (server-side) reads the same project.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Server-side only. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# --- AI collaborator agent (pnpm agent) ---
# Brain auto-selection: ANTHROPIC_API_KEY > local `claude` CLI (subscription,
# dev only) > GEMINI_API_KEY. Force with AGENT_BRAIN=claude|gemini.
# ANTHROPIC_API_KEY=
# AGENT_BRAIN=
# AGENT_MODEL=            # deep brain (claude-opus-4-8 / sonnet / gemini-2.5-flash)
# AGENT_FAST_MODEL=       # reflex brain (haiku / gemini-2.5-flash)
# AGENT_HOCUSPOCUS_URL=   # defaults to NEXT_PUBLIC_HOCUSPOCUS_URL
# AGENT_NOTE_ID=          # pin to one note instead of following the sidebar
# AGENT_NAME=Cogno AI
# AGENT_COLOR=#10B981

# Recall.ai — real-time meeting transcription into notes.
# API key + region from your Recall dashboard (host is https://{region}.recall.ai).
RECALL_API_KEY=
RECALL_REGION=us-west-2
# Public URL of the hocuspocus webhook. It listens on RECALL_PORT (default the
# hocuspocus port + 1 = 1235). For local demos expose it with a tunnel, e.g.
#   ngrok http 1235   →   https://<id>.ngrok-free.app/recall/webhook
RECALL_WEBHOOK_URL=
# Optional: hocuspocus webhook port (default 1235) and transcript language.
# RECALL_PORT=1235
# RECALL_LANGUAGE=ja
