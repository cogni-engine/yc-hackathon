# Cogno AI — resident collaborator agent (headless TipTap client + LLM brain).
#
# Containers have no logged-in `claude` CLI, so the brain must run on an API
# provider: set ANTHROPIC_API_KEY (Claude) or GEMINI_API_KEY + AGENT_BRAIN=gemini.
# Also needs: AGENT_HOCUSPOCUS_URL (ws:// or wss:// realtime server) and
# NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY (notes list).
FROM node:22-slim
RUN corepack enable
WORKDIR /app
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY . .
CMD ["node_modules/.bin/tsx", "agent/index.ts"]
